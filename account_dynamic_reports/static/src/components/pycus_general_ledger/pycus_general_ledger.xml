<?xml version="1.0" encoding="utf-8"?>

<template xml:space="preserve">

    <t t-name="account_dynamic_reports.generalLedger" owl="1">
        <div class="py-header">
            <nav class="navbar navbar-expand-lg bg-white">
              <div class="container-fluid">
                <div class="d-flex">
                    <a class="navbar-brand" href="#"><strong>General Ledger</strong></a>
                </div>
                <div class="d-flex">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ml-auto">
                        <li class="nav-item me-2">
                            <button t-on-click="toggleUnfoldAll" class="btn btn-secondary custom-dropdown">
                                <span t-att-class="state.unfoldAll ? 'fa fa-compress' : 'fa fa-expand'"/>
                                <t t-if="state.unfoldAll"> Collapse All</t>
                                <t t-else=""> Unfold All</t>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button t-on-click="toggleVisibility" class="btn btn-secondary dropdown-toggle custom-dropdown">
                                <span class="fa fa-filter"></span>
                                Filters
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="d-flex align-items-center">
                  <div class="input-group input-group-sm me-3" style="width: 250px;">
                      <span class="input-group-text"><i class="fa fa-search"/></span>
                      <input type="text" class="form-control" placeholder="Search accounts..."
                             t-att-value="state.searchQuery"
                             t-on-input="onSearchInput"/>
                  </div>
                  <ul class="navbar-nav me-auto mb-2 mb-lg-0 ml-auto">

                    <li class="nav-item pycus-button-nav">
                        <button t-on-click="downloadXlsx" class="btn btn-secondary custom-dropdown">
                            <span class="fa fa-download"></span>
                            Xlsx
                        </button>
                    </li>

                      <li class="nav-item pycus-button-nav">
                        <button t-on-click="downloadPdf" class="btn btn-secondary custom-dropdown">
                            <span class="fa fa-download"></span>
                            Pdf
                        </button>
                    </li>

                  </ul>
                  <button class="btn btn-outline-success" t-on-click="apply_filters" type="submit">Apply</button>
                </div>
              </div>
            </nav>
            <hr class="my-1"/>
        </div>

        <div class="pycusFilterBox" t-if="state.isFilterVisible">
            <PycusGeneralLedgerFilters filterValues="state.filterValues" updateValues.bind="getFilterValues"/>
        </div>

        <div id="loading" t-if="state.showLoader">
            <img id="loading-image" src="account_dynamic_reports/static/src/img/Spinner-2.gif" alt="Loading..." />
        </div>

        <div class="py-gl-lines-container bg-white">
            <table class="table py-data-table">
                <thead>
                  <tr class="py-main-thead-tr">
                    <th scope="col"></th>
                    <th scope="col"></th>
                    <th scope="col">Invoice Date</th>
                    <th scope="col">Communication</th>
                    <th scope="col">Partner</th>
                    <th style="text-align:right; cursor:pointer;" scope="col" t-on-click="() => this.onSortColumn('debit')">Debit <i t-att-class="state.sortField === 'debit' ? (state.sortDirection === 'asc' ? 'fa fa-sort-up' : 'fa fa-sort-down') : 'fa fa-sort'" style="opacity:0.4;"/></th>
                    <th style="text-align:right; cursor:pointer;" scope="col" t-on-click="() => this.onSortColumn('credit')">Credit <i t-att-class="state.sortField === 'credit' ? (state.sortDirection === 'asc' ? 'fa fa-sort-up' : 'fa fa-sort-down') : 'fa fa-sort'" style="opacity:0.4;"/></th>
                    <th style="text-align:right; cursor:pointer;" scope="col" t-on-click="() => this.onSortColumn('balance')">Balance <i t-att-class="state.sortField === 'balance' ? (state.sortDirection === 'asc' ? 'fa fa-sort-up' : 'fa fa-sort-down') : 'fa fa-sort'" style="opacity:0.4;"/></th>
                    <th style="text-align:right" scope="col">Debit Currency</th>
                    <th style="text-align:right" scope="col">Credit Currency</th>
                    <th style="text-align:right" scope="col">Balance in Currency</th>
                  </tr>
                </thead>
                <tbody>
                    <t t-if="sortedLines.length > 0">
                        <t t-foreach="sortedLines" t-as="line" t-key="line.time_string">
                            <PycusGeneralLedgerLine gl_line="line" filterValues="state.filterValues" activeId="state.activeId" unfoldAll="state.unfoldAll"/>
                        </t>
                    </t>
                    <t t-else="">
                        <tr>
                            <td colspan="6">
                                <p style="text-align: center">No matching data found!!!</p>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>

    </t>
</template>