<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mssql_direct_sync_form" model="ir.ui.view">
        <field name="name">mssql.direct.sync.form</field>
        <field name="model">mssql.direct.sync</field>
        <field name="arch" type="xml">
            <form string="SQL Server Direct Sync">
                <header>
                    <button name="test_connection" type="object" string="Test Connection" class="oe_stat_button" icon="fa-plug"/>
                    <button name="sync_products" string="Fetch Products" type="object" class="btn-primary"
                            invisible="products_fetched"/>
                    <button name="sync_vendors" string="Fetch Vendors" type="object" class="btn-primary"
                            invisible="vendors_fetched"/>
                    <button name="sync_customers" string="Fetch Customers" type="object" class="btn-primary"
                            invisible="customers_fetched"/>
                    <button name="action_update_products" string="Update Products" type="object" class="btn-secondary"
                            invisible="not products_fetched"/>
                    <button name="action_create_invoice" string="Create Sales Invoices" type="object" class="btn-primary"/>
                    <button name="sync_purchase_invoices" string="Create Vendor Bills" type="object" class="btn-primary"/>
                    <button name="action_repair_backfills"
                            string="Repair Legacy Backfills"
                            type="object" class="btn-warning"
                            icon="fa-wrench"
                            confirm="Cancel all MSSQL-INV-* backfill invoices and redirect their CNs to session aggregates. Run this once after upgrading to the strict-CN version."/>
                </header>
                <sheet>
                    <group>
                        <group string="Connection Settings">
                            <field name="name"/>
                            <field name="server"/>
                            <field name="port"/>
                            <field name="database"/>
                            <field name="username"/>
                            <field name="password" password="True"/>
                            <field name="trust_cert"/>
                        </group>
                        <group string="Sync Settings">
                            <field name="invoice_date"/>
                            <field name="purchase_invoice_date"/>
                            <field name="products_fetched" readonly="1"/>
                            <field name="vendors_fetched" readonly="0"/>
                            <field name="customers_fetched" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sales Payment Methods" name="sales_payment_methods">
                            <div class="oe_button_box" name="sales_pm_buttons">
                                <button name="action_fetch_sales_payment_methods"
                                        type="object"
                                        string="Fetch Sales Payment Methods"
                                        class="btn-primary"
                                        icon="fa-download"/>
                            </div>
                            <field name="sales_payment_method_ids" nolabel="1"
                                   context="{'default_scope': 'sales', 'default_sync_config_id': id}">
                                <list editable="bottom">
                                    <field name="mssql_code" readonly="1"/>
                                    <field name="name"/>
                                    <field name="journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="scope" column_invisible="1"/>
                                </list>
                            </field>
                            <div class="alert alert-info" role="alert" style="margin: 10px;">
                                <strong>How it works:</strong> Hit
                                <em>Fetch Sales Payment Methods</em> to pull every
                                PaymentType from MSSQL (<code>tblPaymentType</code> +
                                any orphan codes in <code>tblCashierActivityDetail</code>),
                                then assign a journal to each. Any payment whose code
                                isn't mapped will cause the queue line to fail with a
                                clear error. PT5 (return voucher) is intentionally
                                excluded — it's reconciled via credit notes.
                            </div>
                        </page>
                        <page string="Purchase Payment Methods" name="purchase_payment_methods">
                            <div class="oe_button_box" name="purchase_pm_buttons">
                                <button name="action_fetch_purchase_payment_methods"
                                        type="object"
                                        string="Fetch Purchase Payment Methods"
                                        class="btn-primary"
                                        icon="fa-download"/>
                            </div>
                            <field name="purchase_payment_method_ids" nolabel="1"
                                   context="{'default_scope': 'purchase', 'default_sync_config_id': id}">
                                <list editable="bottom">
                                    <field name="mssql_code" readonly="1"/>
                                    <field name="name"/>
                                    <field name="journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="scope" column_invisible="1"/>
                                </list>
                            </field>
                            <div class="alert alert-info" role="alert" style="margin: 10px;">
                                <strong>How it works:</strong> Distinct
                                <code>PaymentMethod</code> values from
                                <code>tblSuppliersPayment</code>. Unmapped methods
                                cause vendor-bill queue lines to fail.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mssql_direct_sync_list" model="ir.ui.view">
        <field name="name">mssql.direct.sync.list</field>
        <field name="model">mssql.direct.sync</field>
        <field name="arch" type="xml">
            <list string="SQL Server Direct Connections">
                <field name="name"/>
                <field name="server"/>
                <field name="database"/>
                <field name="products_fetched"/>
                <field name="vendors_fetched"/>
                <field name="customers_fetched"/>
            </list>
        </field>
    </record>

    <record id="action_mssql_direct_sync" model="ir.actions.act_window">
        <field name="name">Direct Invoice Sync</field>
        <field name="res_model">mssql.direct.sync</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new SQL Server connection for direct invoice sync
            </p>
        </field>
    </record>

    <menuitem id="menu_mssql_direct_root" name="SQL Direct Invoice Sync" sequence="101"/>
    <menuitem id="menu_mssql_direct_sync" name="Connection"
              action="action_mssql_direct_sync"
              parent="menu_mssql_direct_root"
              sequence="10"/>
</odoo>
