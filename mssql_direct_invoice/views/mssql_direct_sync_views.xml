<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mssql_direct_sync_form" model="ir.ui.view">
        <field name="name">mssql.direct.sync.form</field>
        <field name="model">mssql.direct.sync</field>
        <field name="arch" type="xml">
            <form string="SQL Server Direct Sync">
                <header>
                    <button name="test_connection" type="object" string="Test Connection" class="oe_stat_button" icon="fa-plug"/>
                    <button name="sync_products" string="Fetch Products" type="object" class="btn-primary"
                            invisible="products_fetched"/>
                    <button name="sync_vendors" string="Fetch Vendors" type="object" class="btn-primary"
                            invisible="vendors_fetched"/>
                    <button name="sync_customers" string="Fetch Customers" type="object" class="btn-primary"
                            invisible="customers_fetched"/>
                    <button name="action_update_products" string="Update Products" type="object" class="btn-secondary"
                            invisible="not products_fetched"/>
                    <button name="action_create_invoice" string="Create Sales Invoices" type="object" class="btn-primary"/>
                    <button name="sync_purchase_invoices" string="Create Vendor Bills" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Connection Settings">
                            <field name="name"/>
                            <field name="server"/>
                            <field name="port"/>
                            <field name="database"/>
                            <field name="username"/>
                            <field name="password" password="True"/>
                            <field name="trust_cert"/>
                        </group>
                        <group string="Sync Settings">
                            <field name="invoice_date"/>
                            <field name="purchase_invoice_date"/>
                            <field name="products_fetched" readonly="1"/>
                            <field name="vendors_fetched" readonly="0"/>
                            <field name="customers_fetched" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Payment Method Journal Mapping" name="payment_journal_mapping">
                            <group>
                                <group string="Cash Payment Methods">
                                    <field name="payment_method_cash_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_coupon_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_points_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                </group>
                                <group string="Bank/Card Payment Methods">
                                    <field name="payment_method_mada_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_visa_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_mastercard_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_stcpay_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_onaccount_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="payment_method_banktransfer_journal_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert" style="margin: 10px;">
                                <strong>Optional Configuration:</strong> Map payment methods to specific journals.
                                If not configured, payments will use default cash/bank journals.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mssql_direct_sync_list" model="ir.ui.view">
        <field name="name">mssql.direct.sync.list</field>
        <field name="model">mssql.direct.sync</field>
        <field name="arch" type="xml">
            <list string="SQL Server Direct Connections">
                <field name="name"/>
                <field name="server"/>
                <field name="database"/>
                <field name="products_fetched"/>
                <field name="vendors_fetched"/>
                <field name="customers_fetched"/>
            </list>
        </field>
    </record>

    <record id="action_mssql_direct_sync" model="ir.actions.act_window">
        <field name="name">Direct Invoice Sync</field>
        <field name="res_model">mssql.direct.sync</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new SQL Server connection for direct invoice sync
            </p>
        </field>
    </record>

    <menuitem id="menu_mssql_direct_root" name="SQL Direct Invoice Sync" sequence="101"/>
    <menuitem id="menu_mssql_direct_sync" name="Connection"
              action="action_mssql_direct_sync"
              parent="menu_mssql_direct_root"
              sequence="10"/>
</odoo>
